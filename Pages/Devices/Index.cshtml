@page
@model AiBoxCenter.Pages.Devices.IndexModel
@{ ViewData["Title"] = "設備管理"; }

<div class="content-area" style="max-width:100%; height:auto; overflow:visible;">
    <div class="content-header">
        <h2>設備管理</h2>
        <button onclick="openDeviceModal('create')" class="ant-btn">+ 新增設備</button>
    </div>
    
    <table id="deviceTable" class="display" style="width:100%">
        <thead>
            <tr>
                <th style="width:5%">啟用</th>
                <th style="width:20%">名稱</th>
                <th style="width:15%">序號 (SN)</th>
                <th style="width:15%">IP:Port</th>
                <th style="width:15%">MQTT IP:Port</th>
                <th style="width:15%">MQTT SN</th>
                <th style="width:15%">操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Devices) 
            { 
                <tr>
                    <td class="text-center"><input type="checkbox" checked="@item.IsEnable" disabled /></td>
                    <td style="font-weight:500;">@item.DeviceName</td>
                    <td class="cell-nowrap">@item.DeviceSerialNo</td>
                    <td class="cell-nowrap">@item.DeviceIP:@item.DevicePort</td>
                    <td class="cell-nowrap">@(string.IsNullOrEmpty(item.MqttIP) ? "-" : $"{item.MqttIP}:{item.MqttPort}")</td>
                    <td class="cell-nowrap">@(string.IsNullOrEmpty(item.MqttSerialNo) ? "-" : item.MqttSerialNo)</td>
                    <td>
                        <button class="link-btn small-btn login-btn" onclick="webLogin('@item.DeviceIP', '@item.DevicePort')">AiBox Login</button> 
                        <button class="link-btn small-btn" onclick='openDeviceModal("edit", @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(item)))'>編輯</button> 
                        <button class="link-btn danger small-btn" onclick="deleteDevice(@item.Id)">刪除</button>
                    </td>
                </tr> 
            }
        </tbody>
    </table>
</div>

<form id="deleteForm" method="post" asp-page-handler="Delete">
    <input type="hidden" name="id" id="deleteId" />
</form>

<div id="deviceModal" class="custom-modal">
    <div class="modal-content" style="width:600px;">
        <div class="modal-header">
            <h5 id="modalTitle">新增設備</h5>
            <button type="button" onclick="closeModal()" class="close-btn">✕</button>
        </div>
        <form method="post">
            <div class="modal-body" style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; overflow-y:auto; max-height:70vh;">
                <input type="hidden" asp-for="DeviceInput.Id" id="dId" />
                
                <div style="grid-column: span 2; display:flex; align-items:center;">
                    <label style="margin-right:10px; margin-bottom:0;">啟用設備</label>
                    <input type="checkbox" asp-for="DeviceInput.IsEnable" id="dEnable" style="width:auto;" />
                </div>

                <div style="grid-column: span 2;"><label>名稱</label><input asp-for="DeviceInput.DeviceName" id="dName" class="ant-input" required /></div>
                <div><label>IP</label><input asp-for="DeviceInput.DeviceIP" id="dIp" class="ant-input" required /></div>
                <div><label>Port</label><input asp-for="DeviceInput.DevicePort" id="dPort" class="ant-input" required /></div>
                
                <div><label>序號 (SN)</label><input asp-for="DeviceInput.DeviceSerialNo" id="dSn" class="ant-input" required /></div>
                <div><label>帳號</label><input asp-for="DeviceInput.DeviceUser" id="dUser" class="ant-input" required /></div>
                <div><label>密碼</label><input asp-for="DeviceInput.DevicePassword" id="dPass" class="ant-input" required /></div>
                
                <div style="grid-column: span 2; border-top:1px solid #eee; margin-top:10px; padding-top:10px;">
                    <strong>MQTT 設定 (選填)</strong>
                </div>
                
                <div><label>MQTT IP</label><input asp-for="DeviceInput.MqttIP" id="mIp" class="ant-input" /></div>
                <div><label>MQTT Port</label><input asp-for="DeviceInput.MqttPort" id="mPort" class="ant-input" /></div>
                <div><label>MQTT SN</label><input asp-for="DeviceInput.MqttSerialNo" id="mSn" class="ant-input" /></div>
                <div><label>MQTT User</label><input asp-for="DeviceInput.MqttUser" id="mUser" class="ant-input" /></div>
                <div><label>MQTT Password</label><input asp-for="DeviceInput.MqttPassword" id="mPass" class="ant-input" /></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="ant-btn" style="background:#888; border-color:#888; margin-right:10px;" onclick="closeModal()">取消</button>
                <button type="submit" class="ant-btn">儲存</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#deviceTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/zh-HANT.json" },
                "autoWidth": false
            });
        });

        function webLogin(ip, port) {
            var url = "http://" + ip + ":" + port;
            var win = window.open(url, '_blank');
            if (win && win.document.documentElement.requestFullscreen) {
                win.onload = function() { win.document.documentElement.requestFullscreen(); };
            }
        }

        function openDeviceModal(mode, data) {
            var form = $('#deviceModal form');
            $('#dId').val(0); $('#dName').val(''); $('#dIp').val(''); $('#dPort').val(''); $('#dSn').val(''); $('#dUser').val(''); $('#dPass').val('');
            $('#mIp').val(''); $('#mPort').val(''); $('#mSn').val(''); $('#mUser').val(''); $('#mPass').val('');
            $('#dEnable').prop('checked', true); 

            if (mode === 'create') {
                $('#modalTitle').text('新增設備');
                form.attr('action', '?handler=Create');
            } else {
                $('#modalTitle').text('編輯設備');
                form.attr('action', '?handler=Edit');
                if(data) {
                    $('#dId').val(data.Id); $('#dName').val(data.DeviceName); $('#dIp').val(data.DeviceIP); $('#dPort').val(data.DevicePort);
                    $('#dSn').val(data.DeviceSerialNo); $('#dUser').val(data.DeviceUser); $('#dPass').val(data.DevicePassword);
                    $('#mIp').val(data.MqttIP); $('#mPort').val(data.MqttPort); $('#mSn').val(data.MqttSerialNo); $('#mUser').val(data.MqttUser); $('#mPass').val(data.MqttPassword);
                    $('#dEnable').prop('checked', data.IsEnable);
                }
            }
            $('#deviceModal').css('display', 'flex');
        }

        function closeModal() {
            $('#deviceModal').hide();
        }

        function deleteDevice(id) {
            if(confirm('確定刪除此設備？')) {
                $('#deleteId').val(id);
                $('#deleteForm').submit();
            }
        }
    </script>
}