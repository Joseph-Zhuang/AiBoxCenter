@page
@model AiBoxCenter.Pages.Cameras.DeviceMonitorModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-tw">
<head>
    <meta charset="utf-8" />
    <title>Device Monitor (WebSocket Mode)</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: sans-serif;
            overflow: hidden;
            background-color: #000;
        }

        .monitor-toolbar {
            background: #1a1a1a;
            color: white;
            padding: 0 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            height: 50px;
            box-sizing: border-box;
            border-bottom: 1px solid #333;
        }

        /* 雙分割容器 */
        #displayContainer {
            display: flex;
            width: 100%;
            height: calc(100vh - 50px);
        }

        /* 75% 地圖區域 */
        #displayCanvas {
            width: 75%;
            height: 100%;
            position: relative;
            background-size: 100% 100%;
            background-position: center;
            background-repeat: no-repeat;
            border-right: 1px solid #333;
            overflow: hidden;
        }

        /* 25% 告警紀錄區域 */
        #alarmCanvas {
            width: 25%;
            height: 100%;
            background-color: #111;
            color: #00ff00; /* 科技綠 */
            font-family: 'Courier New', Courier, monospace;
            font-size: 13px;
            padding: 10px;
            box-sizing: border-box;
            overflow-y: auto;
            border-left: 1px solid #444;
        }

        .camera-marker {
            position: absolute;
            text-align: center;
            width: 60px;
        }

            .camera-marker img {
                width: 40px;
                height: 40px;
            }

        .camera-label {
            font-size: 11px;
            color: #fff;
            background: rgba(0,0,0,0.7);
            padding: 2px 5px;
            border-radius: 3px;
            display: inline-block;
        }

        .btn-fullscreen {
            margin-left: auto;
            background: #444;
            color: #fff;
            border: 1px solid #666;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 4px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            background: gray;
            margin-right: 5px;
        }
    </style>
</head>
<body>

    <input type="hidden" id="wsUrl" value="@Model.WsUrl" />

    <form method="get" id="monitorForm">
        <div class="monitor-toolbar">
            <div id="wsStatus" class="status-dot"></div>
            <label>Area:</label>
            <select name="areaId" onchange="this.form.submit()">
                @foreach (var area in Model.Areas)
                {
                    <option value="@area.Id" selected="@(Model.SelectedAreaId == area.Id)">@area.AreaName</option>
                }
            </select>
            <span id="wsStatusText" style="font-size: 12px; color: #aaa;">Disconnected</span>

            <button type="button" class="btn-fullscreen" onclick="toggleFullScreen()">⛶ Full Screen</button>
        </div>

        <div id="displayContainer">
            <div id="displayCanvas" style="background-image: url('@Url.Content(Model.BackgroundImageUrl ?? "")');">
                @if (Model.SelectedAreaId.HasValue)
                {
                    @foreach (var cam in Model.PlacedCameras)
                    {
                        <div class="camera-marker" style="left: @(cam.LocationX)px; top: @(cam.LocationY)px;">
                            <img src="~/images/cctv_2709318.png" alt="Camera" />
                            <div class="camera-label">@cam.Name</div>
                        </div>
                    }
                }
            </div>

            <div id="alarmCanvas">
                [系統預備中...]<br>
            </div>
        </div>
    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const wsUrl = document.getElementById("wsUrl").value;
            const alarmCanvas = document.getElementById("alarmCanvas");
            const statusDot = document.getElementById("wsStatus");
            const statusText = document.getElementById("wsStatusText");

            // 初始化 WebSocket 連線
            function connectWebSocket() {
                const socket = new WebSocket(wsUrl);

                socket.onopen = function (e) {
                    statusDot.style.background = "#00ff00";
                    statusText.innerText = "Connected: " + wsUrl;
                    alarmCanvas.innerHTML += ">> WebSocket Connected.<br>";
                };

                socket.onmessage = function (event) {
                    try {
                        const data = JSON.parse(event.data);

                        // 格式化顯示訊息 (依據 AlarmActionRequest 格式)
                        const timestamp = data.time || new Date().toLocaleTimeString();
                        const device = data.deviceName || "Unknown Device";
                        const type = data.alarmTypeName || "Alert";

                        const msgHtml = `[${timestamp}] <b>${device}</b>: ${type}<br>`;

                        // 插入至最上方或最下方
                        alarmCanvas.innerHTML = msgHtml + alarmCanvas.innerHTML;

                        // 限制最大顯示筆數以保持效能
                        if (alarmCanvas.childElementCount > 100) {
                            alarmCanvas.lastChild.remove();
                        }
                    } catch (err) {
                        console.error("Data parse error", err);
                        alarmCanvas.innerHTML = `>> Raw Msg: ${event.data}<br>` + alarmCanvas.innerHTML;
                    }
                };

                socket.onclose = function (e) {
                    statusDot.style.background = "red";
                    statusText.innerText = "Disconnected. Retrying...";
                    setTimeout(connectWebSocket, 5000); // 5秒後重連
                };

                socket.onerror = function (err) {
                    console.error("Socket error", err);
                    socket.close();
                };
            }

            connectWebSocket();
        });

        function toggleFullScreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                document.exitFullscreen();
            }
        }
    </script>

</body>
</html>
